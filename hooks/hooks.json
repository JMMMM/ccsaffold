{
  "hooks": {
    "SessionEnd": [{
      "matcher": "",
      "hooks": [{
        "type": "command",
        "command": "TRIGGER_SOURCE=project_hook bash ${CLAUDE_PLUGIN_ROOT}/scripts/session-end-hook.sh ${SESSION_ID}"
      }]
    }],
    "SessionStart": [{
      "matcher": "",
      "hooks": [{
        "type": "command",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/session-check-recent.js"
      }]
    }],
    "Notification": [{
      "matcher": "",
      "hooks": [{
        "type": "command",
        "command": "${CLAUDE_PLUGIN_ROOT}/scripts/notification-hook.sh"
      }]
    }]
  }
}
